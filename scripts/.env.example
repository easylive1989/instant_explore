# Local scripts environment (NOT the backend/server env).
# Copy to scripts/.env and fill in. Used by the host-only tools under
# scripts/ (metrics, unsplash_images, daily_video_post, publish_reel,
# manual_daily_story).

# ── Metrics skill (lorescape-metrics) ─────────────────────────────────────────
# Google Search Console site URL for reading search performance metrics.
GSC_SITE_URL=sc-domain:example.app
# Google Analytics 4 property IDs (web + mobile app).
GA4_PROPERTY_ID_WEB=
GA4_PROPERTY_ID_APP=
# Service-account JSON used by GSC / GA4 / Sheets clients.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/metrics-sa.json
# Google Sheet the metrics report accumulates into (one tab per source).
METRICS_SHEET_ID=

# ── Unsplash (daily-story cover image search) ─────────────────────────────────
# Free demo key (50 req/hr): https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Instagram Business via Meta Graph API ─────────────────────────────────────
# Shared with backend/.env (server uses these to publish; metrics + publish_reel
# read them here). Keep both copies in sync when the token rotates.
# IG Business Account ID (numeric) linked to your Facebook Page.
IG_USER_ID=
# Long-lived Page access token. Obtain via:
#   scripts/meta_token_helper.py --platform instagram
META_PAGE_ACCESS_TOKEN=
