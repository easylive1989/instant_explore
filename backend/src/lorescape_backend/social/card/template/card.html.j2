<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8" />
{# `base_url` is injected by the Playwright renderer so relative paths
   (card.css, ./fonts/...) resolve via file://. Pure-HTML unit tests
   pass an empty string, which yields a no-op <base href="">. #}
<base href="{{ base_url }}" />
<link rel="stylesheet" href="card.css" />
</head>
<body>
{# `slide` selects which plate(s) to render for the carousel:
     None     → legacy combined card (photo + text on one image)
     'cover'  → photo plate only, full height (grid thumbnail face)
     'story'  → text plate only, full height (readable story page)
     'cta'    → closing call-to-action page
   Keeping the None branch byte-for-byte preserves the existing
   single-image tests. #}
<div class="ls-card{% if slide %} ls-card--{{ slide }}{% endif %}">
  {% if not slide or slide == 'cover' %}
  {# ============ PHOTO PLATE ============ #}
  <div class="ls-photo">
    <div class="ls-photo__img" style="background-image: url('{{ content.photo_url | safe }}');"></div>
    <div class="ls-photo__tint"></div>
    <div class="ls-photo__grain"></div>

    <div class="ls-spine"><span>{{ content.location_en }}</span></div>

    <div class="ls-coord">
      <div class="ls-coord__year">Anno · {{ content.anno_roman }}</div>
      <div>{{ content.location_coord }}</div>
    </div>

    {% if slide == 'cover' %}
    <div class="ls-seal"><span>{{ content.city_ch }}</span></div>
    {% endif %}

    <div class="ls-title">
      <h1 class="ls-title__ch">{{ content.title_ch }}</h1>
      <p class="ls-title__ch-sub">{{ content.title_ch_sub }}</p>
    </div>
  </div>
  {% endif %}

  {% if not slide or slide == 'story' %}
  {# ============ TEXT PLATE (ZH-only, single column) ============ #}
  <div class="ls-text ls-text--single is-ch">
    <div class="ls-folio ls-folio--seal">
      <span class="ls-folio__num"><span class="ls-folio__seal"></span></span>
    </div>

    {% for paragraph in content.paragraphs_ch %}
      <div class="ls-verse {% if loop.first %}ls-verse--first{% endif %}">
        <div class="ls-verse__ch">
          <p class="ls-body-ch">
            {% if loop.first %}<span class="ls-dropcap">{{ paragraph[:1] }}</span>{{ paragraph[1:] }}{% else %}{{ paragraph }}{% endif %}
          </p>
        </div>
      </div>
    {% endfor %}

    <div class="ls-quote">
      <p class="ls-quote__ch">{{ content.pull_quote_ch }}</p>
      <p class="ls-quote__attrib">{{ content.pull_quote_attrib_ch }}</p>
    </div>

    <div class="ls-foot">
      <span>{{ content.location_ch }} · {{ content.city_ch }} {{ content.city_en }}</span>
      <span class="ls-foot__brand">Lorescape</span>
    </div>
  </div>
  {% endif %}

  {% if slide == 'cta' %}
  {# ============ CTA PLATE (closing slide) ============ #}
  <div class="ls-cta">
    <div class="ls-cta__seal">聽</div>
    <p class="ls-cta__lead">聽它親口說完這段故事。</p>
    <div class="ls-cta__rule"></div>
    <p class="ls-cta__brand">Lorescape</p>
    <p class="ls-cta__tagline">AI 旅行說書人</p>
    <p class="ls-cta__action">下載連結在個人簡介 ↓</p>
  </div>
  {% endif %}
</div>
</body>
</html>
