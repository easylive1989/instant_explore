# Supabase (use the SERVICE_ROLE key — bypasses RLS for writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gemini (Google AI Studio key)
GEMINI_API_KEY=your_gemini_api_key

# Discord webhook for failure alerts (optional but recommended)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Discord review bot ────────────────────────────────────────────────────────
# Required for the 21:00 publish job to read ✅/❌ reactions before posting.
# See docs/social_publisher_setup.md for setup steps.
DISCORD_BOT_TOKEN=
DISCORD_REVIEW_CHANNEL_ID=
# Comma-separated Discord user IDs allowed to approve/reject (your own ID first)
DISCORD_APPROVER_IDS=

# ── Threads (Meta) ────────────────────────────────────────────────────────────
# Long-lived Threads user access token (valid 60 days — refresh before expiry).
# Obtain via: scripts/meta_token_helper.py --platform threads
# See docs/social_publisher_setup.md for the full OAuth flow.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── Instagram Business via Meta Graph API ─────────────────────────────────────
# IG Business Account ID (numeric) linked to your Facebook Page.
# Obtain via: scripts/meta_token_helper.py --platform instagram
# See docs/social_publisher_setup.md for setup steps.
IG_USER_ID=
# Long-lived Page access token (never expires when generated from a
# long-lived user token). Obtain via: scripts/meta_token_helper.py --platform instagram
META_PAGE_ACCESS_TOKEN=

# ── Branding ──────────────────────────────────────────────────────────────────
# @ handle stamped into every published post (no leading @).
BRAND_HANDLE_THREADS=@instant_explore
BRAND_HANDLE_IG=@instant_explore
# CTA_TEXT=Explore more places with Instant Explore.
