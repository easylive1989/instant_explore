# Supabase (use the SERVICE_ROLE key — bypasses RLS for writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gemini (Google AI Studio key)
GEMINI_API_KEY=your_gemini_api_key

# Narration Google-Search grounding (default on). Set to 0 to restore the
# legacy Wikipedia-only narration behaviour (kill-switch if grounding
# quota/cost becomes a problem). Grounding pricing: 1,500 req/day free on
# the paid tier, then $35 per 1,000 grounded prompts.
# NARRATION_WEB_SEARCH=1

# Discord webhook for failure alerts (optional but recommended)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Discord review bot ────────────────────────────────────────────────────────
# Required for the 21:00 publish job to read ✅/❌ reactions before posting.
# See docs/social_publisher_setup.md for setup steps.
DISCORD_BOT_TOKEN=
DISCORD_REVIEW_CHANNEL_ID=
# Comma-separated Discord user IDs allowed to approve/reject (your own ID first)
DISCORD_APPROVER_IDS=

# ── Instagram Business via Meta Graph API ─────────────────────────────────────
# IG Business Account ID (numeric) linked to your Facebook Page.
# Obtain via: scripts/meta_token_helper.py --platform instagram
# See docs/social_publisher_setup.md for setup steps.
IG_USER_ID=
# Long-lived Page access token (never expires when generated from a
# long-lived user token). Obtain via: scripts/meta_token_helper.py --platform instagram
META_PAGE_ACCESS_TOKEN=

# ── Branding ──────────────────────────────────────────────────────────────────
# @ handle stamped into every published post (no leading @).
BRAND_HANDLE_IG=@instant_explore
# CTA_TEXT=Explore more places with Instant Explore.

# ── RevenueCat (subscription source of truth) ─────────────────────────────────
# Shared secret guarding POST /webhooks/revenuecat. Must EXACTLY match the
# "Authorization" header value configured on the webhook in the RevenueCat
# dashboard. Absent → the webhook endpoint returns 503.
REVENUECAT_WEBHOOK_AUTH_TOKEN=
# RevenueCat secret API key (v1) used by the nightly reconcile job to re-read
# subscriber status. Absent → reconcile is skipped (webhook still works).
REVENUECAT_API_KEY=

# ── Perplexica (DEMO / spike only — not used by production yet) ───────────────
# Base URL of a self-hosted Perplexica ("Vane") instance used to augment
# narration source material with web research. See backend/demo/perplexica/.
# Defaults to http://localhost:3000 when unset. Only the demo script
# (scripts/perplexica_demo.py) reads this.
PERPLEXICA_URL=http://localhost:3000
