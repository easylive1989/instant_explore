# Supabase (use the SERVICE_ROLE key — bypasses RLS for writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Gemini backend ────────────────────────────────────────────────────────────
# Which backend the story + narration generators use:
#   ai-studio (default) — authenticate with GEMINI_API_KEY below.
#   vertex              — route through a GCP project so the bound billing
#                         account / AI Pro credit applies. No key in code;
#                         auth comes from GCP Application Default Credentials.
# GEMINI_BACKEND=ai-studio

# Google AI Studio key. Required when GEMINI_BACKEND=ai-studio; ignored on
# the vertex backend.
GEMINI_API_KEY=your_gemini_api_key

# Vertex AI settings. Required when GEMINI_BACKEND=vertex.
#   GOOGLE_CLOUD_PROJECT  — GCP project ID (e.g. instant-explore-7b442).
#   GOOGLE_CLOUD_LOCATION — region; defaults to us-central1 (broad model
#                           availability). asia-east1 = Taiwan/Changhua.
# Credentials are resolved automatically by the SDK — NOT set here:
#   • locally:  gcloud auth application-default login
#   • server:   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=instant-explore-7b442
# GOOGLE_CLOUD_LOCATION=us-central1

# Narration Google-Search grounding (default on). Set to 0 to restore the
# legacy Wikipedia-only narration behaviour (kill-switch if grounding
# quota/cost becomes a problem). Grounding pricing: 1,500 req/day free on
# the paid tier, then $35 per 1,000 grounded prompts.
# NARRATION_WEB_SEARCH=1

# ── RevenueCat (subscription source of truth) ─────────────────────────────────
# Shared secret guarding POST /webhooks/revenuecat. Must EXACTLY match the
# "Authorization" header value configured on the webhook in the RevenueCat
# dashboard. Absent → the webhook endpoint returns 503.
REVENUECAT_WEBHOOK_AUTH_TOKEN=
# RevenueCat secret API key (v1) used by the nightly reconcile job to re-read
# subscriber status. Absent → reconcile is skipped (webhook still works).
REVENUECAT_API_KEY=

# ── Perplexica (DEMO / spike only — not used by production yet) ───────────────
# Base URL of a self-hosted Perplexica ("Vane") instance used to augment
# narration source material with web research. See backend/demo/perplexica/.
# Defaults to http://localhost:3000 when unset. Only the demo script
# (scripts/perplexica_demo.py) reads this.
PERPLEXICA_URL=http://localhost:3000

# Host-only script config (metrics, Unsplash, etc.) lives in scripts/.env —
# see scripts/.env.example. It is NOT read by the backend/server.

# Social publishing 與 daily story 的環境變數在 publisher/.env — 見 publisher/.env.example。
